# ─── Required ───
# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_jwt

# OpenAI (AI Assistant)
OPENAI_API_KEY=sk-proj-xxx
# OPENAI_MODEL=gpt-4o-mini  # optional override (default: gpt-4o-mini)

# App config
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_WHATSAPP_NUMBER=5582999999999

# ─── Optional ───
# GeckoAPI (used by /api/properties/import-airbnb to scrape listings)
GECKOAPI_TOKEN=pk_live_xxx_or_pk_test_xxx

# ─── WhatsApp / Evolution (Phase C — only required to wire to a real provider) ───
# Generate WHATSAPP_WEBHOOK_SECRET with: openssl rand -hex 32
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_OUTBOUND_WEBHOOK_URL=https://n8n.example/webhook/whatsapp-outbound
# n8n endpoint that sets/deletes Redis `paused:{phone}` for the Sales workflow.
# Receives {action:"pause"|"resume", contact_phone, conversation_id} + X-Webhook-Secret.
WHATSAPP_AI_CONTROL_WEBHOOK_URL=https://n8n.example/webhook/milagres-sales-ai-control
EVOLUTION_API_URL=https://evo.example.com
EVOLUTION_API_KEY=
EVOLUTION_DEFAULT_INSTANCE=
