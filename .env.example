# ─── Required ───
# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_legacy_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_jwt

# OpenAI (AI Assistant)
OPENAI_API_KEY=sk-proj-xxx
# OPENAI_MODEL=gpt-4o-mini  # optional override (default: gpt-4o-mini)

# App config
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_WHATSAPP_NUMBER=5582999999999

# ─── Optional ───
# GeckoAPI (used by /api/properties/import-airbnb to scrape listings)
GECKOAPI_TOKEN=pk_live_xxx_or_pk_test_xxx
